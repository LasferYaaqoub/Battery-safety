<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.ChargingFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            android:orientation="vertical">

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fitsSystemWindows="true"
                app:columnCount="2">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_columnSpan="2"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/_20sdp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amperage"
                            android:textSize="@dimen/_11ssp"
                            app:layout_constraintEnd_toEndOf="@+id/speed_view_amp"
                            app:layout_constraintStart_toStartOf="@+id/speed_view_amp"

                            app:layout_constraintTop_toBottomOf="@+id/speed_view_amp" />
                        <TextView
                            android:id="@+id/tv_min_amperage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Min"
                            android:textSize="@dimen/_15ssp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.1"
                            app:layout_constraintStart_toStartOf="parent" />

                        <com.github.anastr.speedviewlib.PointerSpeedometer
                            android:id="@+id/speed_view_amp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="@dimen/_100sdp"
                            android:layout_height="@dimen/_100sdp"
                            android:layout_margin="@dimen/_3sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:sv_backgroundCircleColor="#00000000"
                            app:sv_centerCircleColor="#00000000"
                            app:sv_indicatorColor="#3D86BF"
                            app:sv_indicatorWidth="@dimen/_3sdp"
                            app:sv_markColor="#00000000"
                            app:sv_pointerColor="#3D86BF"
                            app:sv_speedTextColor="#00000000"
                            app:sv_speedometerColor="#3D86BF"
                            app:sv_textColor="#00000000"
                            app:sv_unitTextColor="#00000000"
                            app:sv_unitUnderSpeedText="true" />


                        <TextView
                            android:id="@+id/tv_amperage"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/_30sdp"
                            android:gravity="center"
                            android:textSize="@dimen/_15ssp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="0.85" />

                        <TextView
                            android:id="@+id/tv_max_amperage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max"
                            android:textSize="@dimen/_15ssp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.9"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_rowSpan="2"
                    app:layout_rowWeight="1"
                    app:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <com.github.anastr.speedviewlib.PointerSpeedometer
                            android:id="@+id/speed_view_wats"
                            android:layout_width="@dimen/_95sdp"
                            android:layout_height="@dimen/_95sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/textView2"
                            app:layout_constraintVertical_bias="0.20"
                            app:sv_backgroundCircleColor="#00000000"
                            app:sv_centerCircleColor="#00000000"
                            app:sv_indicatorColor="#3D86BF"
                            app:sv_indicatorWidth="@dimen/_3sdp"
                            app:sv_markColor="#00000000"
                            app:sv_pointerColor="#3D86BF"
                            app:sv_speedTextColor="#00000000"
                            app:sv_speedometerColor="#3D86BF"
                            app:sv_textColor="#00000000"
                            app:sv_unitTextColor="#00000000"
                            app:sv_unitUnderSpeedText="true" />


                        <TextView
                            android:id="@+id/textView2"
                            android:layout_width="@dimen/_90sdp"
                            android:layout_height="wrap_content"
                            android:text="Charging speed"
                            android:textSize="@dimen/_11ssp"
                            android:gravity="center"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="0.060000002" />


                        <TextView
                            android:id="@+id/tv_charging_speed"
                            android:layout_width="@dimen/_90sdp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textSize="@dimen/_19ssp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/speed_view_wats"
                            app:layout_constraintVertical_bias="0.20" />

                        <TextView
                            android:id="@+id/tv_statue_of_speed"
                            android:layout_width="@dimen/_90sdp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textSize="@dimen/_15sdp"
                            android:gravity="center"
                            app:layout_constraintEnd_toEndOf="@+id/tv_charging_speed"
                            app:layout_constraintStart_toStartOf="@+id/tv_charging_speed"
                            app:layout_constraintTop_toBottomOf="@+id/tv_charging_speed" />

                    </androidx.constraintlayout.widget.ConstraintLayout>



                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_20sdp">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/_11ssp"
                                android:text="Amp average"/>
                            <TextView
                                android:id="@+id/tv_amp_average"
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:textStyle="bold"
                                android:textSize="@dimen/_14ssp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/flash"
                            android:layout_gravity="bottom|start"
                            />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_rowWeight="1"
                    app:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_20sdp">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="@dimen/_95sdp"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/_11ssp"
                                android:text="Power source"/>
                            <TextView
                                android:id="@+id/tv_power_source"
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:textStyle="bold"
                                android:textSize="@dimen/_14ssp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/flash"
                            android:layout_gravity="bottom|start"
                            />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_20sdp">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="@dimen/_95sdp"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/_11ssp"
                                android:text="Temperature"/>
                            <TextView
                                android:id="@+id/tv_Temperature_charging"
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:textStyle="bold"
                                android:textSize="@dimen/_14ssp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/temperature"
                            android:layout_gravity="bottom|start"
                            />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_15sdp"
                    android:layout_margin="@dimen/_10sdp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_20sdp">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/_11ssp"
                                android:text="Amp statue"/>
                            <TextView
                                android:id="@+id/tv_Amp_statue"
                                android:layout_width="@dimen/_90sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:textStyle="bold"
                                android:textSize="@dimen/_14ssp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <ImageView
                            android:layout_width="@dimen/_30sdp"
                            android:layout_height="@dimen/_30sdp"
                            android:src="@drawable/question_mark"
                            android:layout_gravity="bottom|start"
                            />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>